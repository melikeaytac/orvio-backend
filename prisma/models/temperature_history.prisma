// Extracted model fragment; Prisma CLI still needs a merged schema.
model TemperatureHistory {
  temperature_history_id String   @id @default(uuid())
  device_id              String
  timestamp              DateTime
  internal_temperature   Decimal  @db.Decimal(5, 2)
  source_telemetry_id    String?

  device          Cooler    @relation(fields: [device_id], references: [device_id])
  sourceTelemetry Telemetry? @relation(fields: [source_telemetry_id], references: [telemetry_id])

  @@index([device_id])
  @@index([timestamp])
  @@index([source_telemetry_id])
}
